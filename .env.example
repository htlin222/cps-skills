# robust-lit-review API Configuration
# Copy this file to .env and fill in your API keys
# See: https://github.com/htlin222/robust-lit-review

# Required for literature search
SCOPUS_API_KEY=
PUBMED_API_KEY=
EMBASE_API_KEY=

# Required for DOI validation and open access
UNPAYWALL_EMAIL=

# Required for reference management
ZOTERO_API_KEY=
ZOTERO_LIBRARY_TYPE=user
ZOTERO_LIBRARY_ID=
ZOTERO_COLLECTION_KEY=
